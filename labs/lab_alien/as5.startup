#!/bin/bash

# Configure IPv4 addresses
ip addr add 5.5.2.1/24 dev eth0
ip link set eth0 up

ip addr add 3.5.0.2/30 dev eth1
ip link set eth1 up

ip addr add 5.5.1.1/24 dev eth2
ip link set eth2 up

# Configure IPv6 addresses
# ip -6 addr add 2001:b07:646b:cdbd:797f:3c87:79f:847/64 dev eth0
# ip -6 addr add 2001:db8:1::1/64 dev eth1
# ip -6 addr add 2001:db8:2::1/64 dev eth2

# Start FRR routing service
/etc/init.d/frr start